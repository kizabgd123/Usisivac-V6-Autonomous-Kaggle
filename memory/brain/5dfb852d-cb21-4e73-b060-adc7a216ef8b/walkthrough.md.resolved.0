import logging
import os
import sys
from dotenv import load_dotenv
try:
    import google.generativeai as genai
except ImportError:
    pass

from review_modules.base_module import BaseReviewModule

class LLMVetoBoardReviewModule(BaseReviewModule):
    """
    LLM VetoBoard Review Module.
    Invokes the LLM to review the python code strictly against the 
    Trinity Protocol GEMINI.md Anti-Regression Manifesto.
    """

    def __init__(self, config):
        super().__init__(config)
        self.name = "vetoboard"
        self.description = "LLM Strict Code Auditing (VETO Gate)"
        
        try:
            from config import load_json_safe
            trinity_cfg = load_json_safe("../../trinity_config.json")
        except:
            trinity_cfg = {}
            
        self.llm_settings = trinity_cfg.get("llm_agents", {})
        self.enabled = self.llm_settings.get("vetoboard_enabled", False)
        self.model_name = self.llm_settings.get("model", "gemini-2.5-flash")
        
        load_dotenv()
        
        if self.enabled:
            api_key = os.environ.get("GEMINI_API_KEY")
            if not api_key:
                logging.error("GEMINI_API_KEY is missing. VetoBoard disabled.")
                self.enabled = False
            else:
                genai.configure(api_key=api_key)

    def review_file(self, file_analysis):
        file_path = file_analysis.get("file_path")
        content = file_analysis.get("content", "")

        results = {
            "file": str(file_path),
            "issues": [],
            "score": 100,
            "status": "PASS"
        }

        
        if not self.enabled:
            return results

        if not str(file_path).endswith('.py'):
            return results
            
        logging.info(f"Running LLM VetoBoard Review on {file_path}...")
        
        prompt = f"""
        You are the 'JudgeGuard LLM VetoBoard' strictly enforcing the Trinity Protocol GEMINI.md laws for Kaggle Tabular Competitions.
        Review the following Python code for a machine learning script.
        
        Must VETO if any of the following apply:
        1. Data leakage (e.g., fitting scalers/imputers on the entire dataset before CV splits).
        2. Adding complexity without tracking CV/LB metrics (violating the Anti-Regression manifesto).
        3. Hardcoding metric thresholds instead of loading from trinity_config.json.
        
        Filename: {file_path}
        
        CODE:
        ```python
        {content}
        ```
        
        Respond ONLY in the following JSON format:
        {{
            "status": "VETO" or "PASS",
            "reason": "Short technical reason if VETO, else 'All good.'",
            "line_number": 0,
            "severity": "CRITICAL"
        }}
        """
        
        try:
            model = genai.GenerativeModel(self.model_name)
            response = model.generate_content(prompt)
            # Try to parse the LLM JSON
            import json
            import re
            
            # Extract JSON block
            json_match = re.search(r'\{.*\}', response.text, re.DOTALL)
            if json_match:
                review_data = json.loads(json_match.group(0))
                
                if review_data.get("status") == "VETO":
                    results["status"] = "VETO"
                    results["score"] = 0
                    results["issues"].append({
                        "id": "LLM_VETO",
                        "description": f"VETO TRIGGERED: {review_data.get('reason')}",
                        "line": review_data.get("line_number", 0),
                        "severity": review_data.get("severity", "CRITICAL")
                    })
        except Exception as e:
            logging.error(f"VetoBoard encountered an error: {e}")
            
        return results
