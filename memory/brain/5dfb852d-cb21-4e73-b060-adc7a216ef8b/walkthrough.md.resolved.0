#!/usr/bin/env python3
"""
Boardroom Advisor - Trinity Protocol
Strategic Kaggle Grandmaster AI Agent that parses current project state, 
metrics, and alerts to recommend the next tactical move.
"""

import os
import sys
import json
import logging
from datetime import datetime
from dotenv import load_dotenv

# Load environment variables from .env file
load_dotenv()

try:
    import google.generativeai as genai
except ImportError:
    print("Error: google-generativeai is not installed. Run: pip install google-generativeai")
    sys.exit(1)

logging.basicConfig(level=logging.INFO, format='[%(asctime)s] %(levelname)s - %(message)s')

def load_json_safe(filepath):
    if os.path.exists(filepath):
        try:
            with open(filepath, 'r') as f:
                return json.load(f)
        except Exception as e:
            logging.warning(f"Could not parse {filepath}: {e}")
    return {}

def read_file_safe(filepath, max_lines=50):
    if os.path.exists(filepath):
        try:
            with open(filepath, 'r') as f:
                lines = f.readlines()
                return "".join(lines[-max_lines:])
        except Exception as e:
            logging.warning(f"Could not read {filepath}: {e}")
    return ""

def gather_context():
    """Gathers all relevant context for the Boardroom Advisor."""
    config = load_json_safe("trinity_config.json")
    
    # Check if LLM is enabled
    llm_config = config.get("llm_agents", {})
    if not llm_config.get("boardroom_enabled", False):
        logging.warning("LLM Agents are disabled in trinity_config.json.")
    
    # Get current scores/metrics
    thresholds = config.get("thresholds", {})
    metrics = thresholds.get("metrics", {})
    
    # Get recent guard alerts and logs
    guard_alert = load_json_safe("GUARD_ALERT.json")
    guard_log = read_file_safe("GUARD_LOG.txt", 20)
    
    # Process interactions if available
    top_interactions = read_file_safe("top_interactions.csv", 20)
    
    # Check GEMINI.md rules context
    gemini_rules = read_file_safe("GEMINI.md", 50)
    
    context = {
        "metrics": metrics,
        "guard_alert": guard_alert,
        "guard_log": guard_log,
        "top_interactions": top_interactions,
        "gemini_rules_snippet": gemini_rules
    }
    
    return context, llm_config.get("model", "gemini-2.5-flash")

def generate_strategy(context, model_name):
    """Calls Gemini API to get strategic advice based on context."""
    api_key = os.environ.get("GEMINI_API_KEY")
    if not api_key:
        logging.error("GEMINI_API_KEY environment variable is not set. Cannot run Boardroom Advisor.")
        sys.exit(1)
        
    genai.configure(api_key=api_key)
    
    prompt = f"""
    You are an elite Kaggle Grandmaster acting as the 'Boardroom Strategic Advisor' for the Trinity Protocol tabular ML framework.
    Your job is to read the current state of a tabular classification competition (predicting Churn via ROC AUC) and output the next tactical move.
    
    CURRENT STATE:
    Metrics: {json.dumps(context['metrics'], indent=2)}
    Recent ProcessGuard Alert: {json.dumps(context['guard_alert'], indent=2)}
    Top Feature Interactions snippet:
    {context['top_interactions']}
    
    Follow the 'Anti-Regression Manifesto' rules: do not add complexity without proving CV/LB improvements.
    
    Based on the above, write a detailed, tactical 'Next Steps' plan in Serbian.
    Structure the response with:
    1. Trenutna Situacija (Analysis of metrics and alerts)
    2. Pravac Delovanja (Strategic Direction - e.g., Ensemble, Feature Engineering, New Model type)
    3. Akcioni Koraci (Concrete 1-2-3 steps for the engineer)
    """
    
    logging.info(f"Invoking Gemini model ({model_name}) for Boardroom Strategy...")
    try:
        model = genai.GenerativeModel(model_name)
        response = model.generate_content(prompt)
        return response.text
    except Exception as e:
        logging.error(f"Failed to generate strategy: {e}")
        return None

def write_strategy(strategy_text):
    """Writes the strategy to BOARDROOM_STRATEGY.md"""
    if strategy_text:
        with open("BOARDROOM_STRATEGY.md", "w") as f:
            f.write(f"# Trinity Boardroom Strategy\n\n*Generated on: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}*\n\n")
            f.write(strategy_text)
        logging.info("Strategija uspešno upisana u BOARDROOM_STRATEGY.md")
    else:
        logging.error("No strategy text generated.")

if __name__ == "__main__":
    logging.info("Starting Boardroom Advisor...")
    context, model_name = gather_context()
    strategy = generate_strategy(context, model_name)
    write_strategy(strategy)
