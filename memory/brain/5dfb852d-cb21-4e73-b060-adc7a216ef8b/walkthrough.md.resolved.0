```diff:review.py
#!/usr/bin/env python3
"""
AI-Powered Code Review System - Main CLI Entry Point

This module provides the command-line interface for running comprehensive
code reviews using the Usisivac RAG system.
"""

import argparse
import sys
import os
from pathlib import Path
from typing import List, Optional, Dict, Any
import json
import logging
from datetime import datetime

# Add src to path for imports
sys.path.insert(0, os.path.join(os.path.dirname(__file__)))

from review_engine import ReviewEngine
from config import ReviewConfig
from utils import setup_logging, get_file_stats, format_duration
from review_modules.security_review import SecurityReviewModule
from review_modules.performance_review import PerformanceReviewModule
from review_modules.quality_review import QualityReviewModule
from review_modules.llm_vetoboard_review import LLMVetoBoardReviewModule
from review_db import ReviewDatabase


def parse_arguments():
    """Parse command line arguments."""
    parser = argparse.ArgumentParser(
        description="AI-Powered Code Review System",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Review a single file
  python src/review.py /path/to/file.py

  # Review an entire directory
  python src/review.py /path/to/project --recursive

  # Review with specific categories
  python src/review.py /path/to/project --categories security,performance

  # Review with custom configuration
  python src/review.py /path/to/project --config custom_config.json

  # Review a specific commit/PR (requires git)
  python src/review.py /path/to/project --git-diff HEAD~1

  # Generate different output formats
  python src/review.py /path/to/project --output-format json --output-file review.json
        """
    )

    # Positional argument for target
    parser.add_argument(
        "target",
        help="File, directory, or git reference to review"
    )

    # Optional arguments
    parser.add_argument(
        "--recursive",
        action="store_true",
        help="Recursively scan directories"
    )

    parser.add_argument(
        "--categories",
        default="security,performance,quality,vetoboard",
        help="Comma-separated list of review categories (default: all)"
    )

    parser.add_argument(
        "--config",
        help="Path to custom configuration file (JSON or YAML)"
    )

    parser.add_argument(
        "--git-diff",
        help="Git reference for diff-based review (e.g., HEAD~1, main, feature-branch)"
    )

    parser.add_argument(
        "--output-format",
        choices=["text", "json", "markdown", "html"],
        default="text",
        help="Output format for review results"
    )

    parser.add_argument(
        "--output-file",
        help="File to write review results to (default: stdout)"
    )

    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Enable verbose logging"
    )

    parser.add_argument(
        "--no-interactive",
        action="store_true",
        help="Disable interactive prompts"
    )

    return parser.parse_args()


def main():
    """Main entry point for the code review system."""
    args = parse_arguments()

    # Setup logging
    log_level = logging.DEBUG if args.verbose else logging.INFO
    setup_logging(log_level)

    logging.info("Starting AI-Powered Code Review System")
    logging.info(f"Target: {args.target}")

    # Load configuration
    config = ReviewConfig(args.config)
    logging.info(f"Loaded configuration: {config.config_path}")

    # Initialize review engine and database
    engine = ReviewEngine(config)
    db = ReviewDatabase()
    logging.info("Review engine and database initialized")

    # Determine review scope
    if args.git_diff:
        logging.info(f"Performing git diff review against: {args.git_diff}")
        files_to_review = engine.get_git_diff_files(args.target, args.git_diff)
    else:
        target_path = Path(args.target)
        if not target_path.exists():
            logging.error(f"Target path does not exist: {args.target}")
            sys.exit(1)

        if target_path.is_file():
            files_to_review = [target_path]
        else:
            if args.recursive:
                files_to_review = list(target_path.rglob("*"))
            else:
                files_to_review = list(target_path.glob("*"))

    # Filter files by supported extensions
    files_to_review = [f for f in files_to_review if f.is_file() and f.suffix in config.supported_extensions]
    logging.info(f"Found {len(files_to_review)} files to review")

    # Parse categories
    categories = [c.strip() for c in args.categories.split(",") if c.strip()]
    logging.info(f"Review categories: {categories}")

    # Initialize review modules
    modules = []
    if "security" in categories:
        modules.append(SecurityReviewModule(config))
    if "performance" in categories:
        modules.append(PerformanceReviewModule(config))
    if "quality" in categories:
        modules.append(QualityReviewModule(config))
    if "vetoboard" in categories:
        modules.append(LLMVetoBoardReviewModule(config))

    if not modules:
        logging.warning("No review modules selected - nothing to review")
        sys.exit(0)

    # Perform review
    start_time = datetime.now()
    results = engine.perform_review(files_to_review, modules)
    duration = datetime.now() - start_time

    # Generate report and save to database
    report = engine.generate_report(results, categories, duration)
    db.save_review(results)
    logging.info("Review results saved to history")

    # Output results
    if args.output_file:
        with open(args.output_file, "w", encoding="utf-8") as f:
            if args.output_format == "json":
                json.dump(report, f, indent=2)
            else:
                f.write(report)
        logging.info(f"Review results written to {args.output_file}")
    else:
        print(report)

    logging.info(f"Review completed in {format_duration(duration)}")
    logging.info("AI-Powered Code Review System finished successfully")


if __name__ == "__main__":
    main()
