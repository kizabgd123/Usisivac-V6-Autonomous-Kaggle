import sys
import pandas as pd
import json
import os
import argparse
from datetime import datetime
import subprocess

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
LOG_FILE = os.path.join(SCRIPT_DIR, "CICD_HOOK_LOG.txt")

def log_event(event_type, details):
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    log_entry = f"[{timestamp}] [{event_type}] {details}\n"
    with open(LOG_FILE, "a") as f:
        f.write(log_entry)

def run_judge_guard(submission_file):
    print(f"Running JudgeGuard 7-Gate Protocol on {submission_file}...")
    log_event("START", f"Validation started for {submission_file}")
    
    # 1. Intent Gate
    print("Gate 1: Intent Gate - Check if probabilities or labels...")
    if not os.path.exists(submission_file):
        print(f"Error: Submission file {submission_file} not found.")
        log_event("FAIL", "Intent Gate: File not found")
        return False
    
    df = pd.read_csv(submission_file)
    
    # 2. Identity Gate
    print("Gate 2: Identity Gate - Check pipeline version...")
    manifest_path = 'manifest.json'
    if os.path.exists(manifest_path):
        with open(manifest_path, 'r') as f:
            manifest = json.load(f)
            pipeline_ver = manifest.get('version', 'unknown')
            print(f"Pipeline version: {pipeline_ver}")
            log_event("INFO", f"Identity Gate: Pipeline v{pipeline_ver}")
    else:
        print("Warning: manifest.json not found.")

    # 3. Format Gate
    print("Gate 3: Format Gate - Check column headers...")
    expected_cols = ['id', 'Churn']
    if list(df.columns) != expected_cols:
        print(f"Error: Invalid column headers. Expected {expected_cols}, got {list(df.columns)}")
        log_event("FAIL", "Format Gate: Invalid headers")
        return False

    # 4. Sanity Gate
    print("Gate 4: Sanity Gate - Check number of rows...")
    expected_rows = 254655
    if len(df) != expected_rows:
        print(f"Error: Invalid number of rows. Expected {expected_rows}, got {len(df)}")
        log_event("FAIL", f"Sanity Gate: Invalid rows ({len(df)})")
        return False

    # 5. Dtype Gate
    print("Gate 5: Dtype Gate - Check Float64 for probabilities...")
    if not pd.api.types.is_float_dtype(df['Churn']):
        print(f"Error: Target column should be float, but got {df['Churn'].dtype}")
        log_event("FAIL", "Dtype Gate: Not float")
        return False

    # 6. Value Gate
    print("Gate 6: Value Gate - Check without NaN/OOB...")
    if df['Churn'].isnull().any():
        print("Error: DataFrame contains NaN values.")
        log_event("FAIL", "Value Gate: NaNs found")
        return False
    
    if (df['Churn'] < 0.0).any() or (df['Churn'] > 1.0).any():
        print("Error: Target values are out of bounds (0.0 to 1.0).")
        log_event("FAIL", "Value Gate: OOB values found")
        return False

    # 7. Risk Gate
    print("Gate 7: Risk Gate - Check reasonable average for Churn...")
    mean_val = df['Churn'].mean()
    if mean_val < 0.05 or mean_val > 0.6:
        print(f"Error: Unusual mean value for Churn probabilities: {mean_val}")
        log_event("FAIL", f"Risk Gate: Unusual mean {mean_val}")
        return False
    
    # 8. LLM Veto Gate (Usisivac Check)
    print("Gate 8: LLM Veto Gate - Auditing recently modified scripts...")
    try:
        review_script = os.path.join(SCRIPT_DIR, "Usisivac", "src", "review.py")
        if not os.path.exists(review_script):
            print("Warning: Usisivac review.py not found. Skipping LLM Veto Gate.")
            log_event("SKIP", "LLM Veto Gate: review.py not found")
        else:
            print("Running Usisivac VetoBoard on local python scripts...")
            veto_check = subprocess.run(
                [sys.executable, review_script, SCRIPT_DIR, 
                 "--categories", "vetoboard", "--output-format", "json"],
                capture_output=True, text=True, timeout=120
            )
            
            # Try JSON parsing first, fallback to string matching
            has_veto = False
            try:
                veto_data = json.loads(veto_check.stdout)
                for result in veto_data.get("results", []):
                    for issue in result.get("issues", []):
                        if "VETO" in str(issue.get("id", "")) or "VETO" in str(issue.get("description", "")):
                            has_veto = True
                            break
            except (json.JSONDecodeError, TypeError):
                # Fallback: string matching on stdout
                has_veto = "VETO TRIGGERED" in veto_check.stdout
            
            if has_veto:
                print("Error: LLM VetoBoard triggered on your code. Check Anti-Regression Manifesto.")
                log_event("FAIL", "LLM Veto Gate: Veto Triggered")
                return False
            
    except subprocess.TimeoutExpired:
        print("Warning: LLM Veto Gate timed out after 120s. Skipping.")
        log_event("SKIP", "LLM Veto Gate: Timeout")
    except Exception as e:
        print(f"Warning: LLM Veto Gate encountered an error: {e}")
        # Graceful degradation — don't fail submit if LLM API is down
        
    print("✅ JudgeGuard Protocol Passed. Safe to submit.")
    log_event("PASS", "JudgeGuard Protocol Passed")
    return True

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--no-verify", action="store_true", help="Bypass JudgeGuard verification")
    args = parser.parse_args()

    if args.no_verify:
        print("JudgeGuard verification bypassed via --no-verify")
        log_event("BYPASS", "Verification bypassed manually")
        sys.exit(0)

    # find latest submission file
    submission_files = [f for f in os.listdir('.') if f.startswith('submission') and f.endswith('.csv')]
    if not submission_files:
        print("No submission file found to validate.")
        log_event("SKIP", "No submission files found")
        sys.exit(0)

    # test latest
    latest_file = max(submission_files, key=os.path.getctime)
    if not run_judge_guard(latest_file):
        sys.exit(1)
    
    sys.exit(0)
