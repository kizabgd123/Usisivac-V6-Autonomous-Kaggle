===
import os, gc, time, warnings
import numpy as np
import pandas as pd
import xgboost as xgb
import lightgbm as lgb
import catboost as cb
from sklearn.model_selection import KFold
from sklearn.preprocessing import LabelEncoder
from sklearn.isotonic import IsotonicRegression
from sklearn.metrics import mean_squared_error

warnings.filterwarnings('ignore')

# ═══════════════ CONFIG ═══════════════
BASE_DIR = "/home/kizabgd/Desktop/Istrazivanje/construction_bidding"
TRAIN_SUMMARY = f"{BASE_DIR}/train_summary.csv"
TEST_SUMMARY = f"{BASE_DIR}/test.csv"
RAW_TRAIN = f"{BASE_DIR}/raw_train.csv"
RAW_TEST = f"{BASE_DIR}/raw_test.csv"
SUBMISSION_PATH = f"{BASE_DIR}/submission_v6_elite.csv"

INFLATION_MAP = {
    2018: 1.00, 2019: 1.04, 2020: 1.07, 2021: 1.18, 
    2022: 1.35, 2023: 1.40, 2024: 1.43, 2025: 1.46
}

# ═══════════════ FEATURE ENGINEERING ═══════════════
def get_raw_aggs(df, train_raw=None):
    """Refined aggregations from raw pay-item data with unit-price estimation"""
    if train_raw is not None:
        # Calculate reference unit prices from training data
        train_raw['unit_price'] = train_raw['amount'] / (train_raw['quantity'] + 1e-6)
        item_ref = train_raw.groupby('pay_item_id')['unit_price'].median().to_dict()
        cat_ref = train_raw.groupby('category_id')['unit_price'].median().to_dict()
        global_median = train_raw['unit_price'].median()
        
        # Apply estimation
        df['unit_price_ref'] = df['pay_item_id'].map(item_ref)
        df['unit_price_ref'] = df['unit_price_ref'].fillna(df['category_id'].map(cat_ref))
        df['unit_price_ref'] = df['unit_price_ref'].fillna(global_median)
        df['est_amount'] = df['quantity'] * df['unit_price_ref']
    else:
        # If no trains_raw provided (should not happen in main flow for aggs)
        df['est_amount'] = df['quantity'] # fallback

    agg = df.groupby(['job_id', 'contractor_id']).agg({
        'pay_item_id': 'count',
        'category_id': 'nunique',
        'unit_english_id': 'nunique',
        'quantity': ['sum', 'mean', 'max'],
        'est_amount': ['sum', 'mean', 'max', 'std']
    })
    agg.columns = [
        'item_count', 'cat_unique', 'unit_unique',
        'quant_sum', 'quant_mean', 'quant_max',
        'est_amt_sum', 'est_amt_mean', 'est_amt_max', 'est_amt_std'
    ]
    return agg.reset_index()

def main():
    t0 = time.time()
    print("="*60)
    print(" CONSTRUCTION BIDDING V6 ELITE – TARGET LB < 0.2000 ")
    print("="*60)
    
    # 1. Load Data
    print("[1] Loading and aggregating data...")
    tr_sum = pd.read_csv(TRAIN_SUMMARY)
    te_sum = pd.read_csv(TEST_SUMMARY)
    
    # Efficient loading
    raw_tr = pd.read_csv(f"{BASE_DIR}/raw_train.csv")
    raw_te = pd.read_csv(f"{BASE_DIR}/raw_test.csv")
    
    # Process aggregations with unit price mapping from full raw training
    agg_tr = get_raw_aggs(raw_tr, train_raw=raw_tr)
    agg_te = get_raw_aggs(raw_te, train_raw=raw_tr)
    
    # 2. Merge and Engineer Features
    print("[2] Merging and feature engineering...")
    tr_sum['is_test'] = 0
    te_sum['is_test'] = 1
    full_sum = pd.concat([tr_sum, te_sum], axis=0).reset_index(drop=True)
    full_agg = pd.concat([agg_tr, agg_te], axis=0).reset_index(drop=True)
    
    full = full_sum.merge(full_agg, on=['job_id', 'contractor_id'], how='left')
    
    # Basic cleanup
    full['bid_date'] = pd.to_datetime(full['bid_date'])
    full['year'] = full['bid_date'].dt.year
    full['month'] = full['bid_date'].dt.month
    full['dayofweek'] = full['bid_date'].dt.dayofweek
    full['inflation_idx'] = full['year'].map(INFLATION_MAP).fillna(1.46)
    
    full['bid_year'] = full['bid_date'].dt.year
    full['inf_factor'] = full['bid_year'].map(INFLATION_MAP).fillna(1.0)
    
    # Adjust estimated amount features for inflation
    est_cols = [c for c in full.columns if 'est_amt' in c]
    for c in est_cols:
        full[c] = full[c] * full['inf_factor']
        
    full['bid_month'] = full['bid_date'].dt.month
    full['bid_dow'] = full['bid_date'].dt.dayofweek
    
    # Temporal Dynamics per Contractor
    full = full.sort_values(['contractor_id', 'bid_date'])
    full['days_since_last_bid'] = full.groupby('contractor_id')['bid_date'].diff().dt.days.fillna(365)
    full['cum_bid_count'] = full.groupby('contractor_id').cumcount()
    
    # Contractor Past Success Rate (Approximated by mean bid)
    def expanding_mean(x):
        return x.expanding().mean().shift(1)
    
    full['contractor_avg_bid'] = full.groupby('contractor_id')['total_bid'].transform(expanding_mean)
    
    # Categorical Encoding preparation
    cat_cols = ['contractor_id', 'job_category_description', 'primary_location']
    for col in cat_cols:
        le = LabelEncoder()
        full[col] = le.fit_transform(full[col].astype(str))
    
    # Fill remaining NAs
    num_cols = full.select_dtypes(include=[np.number]).columns
    full[num_cols] = full[num_cols].fillna(0)
    
    # Split back
    train = full[full['is_test'] == 0].copy()
    test = full[full['is_test'] == 1].copy()
    
    # Target Transformation
    y = np.log1p(train['total_bid'])
    drop_cols = ['job_id', 'bid_date', 'total_bid', 'is_test', 'row_id']
    X = train.drop(columns=drop_cols)
    X_test = test.drop(columns=drop_cols)
    
    # 3. Training Loop (Multi-Seed Ensemble)
    seeds = [42, 2026]
    N_FOLDS = 5
    oof = np.zeros(len(X))
    test_preds = np.zeros(len(X_test))
    
    print(f"[3] Starting CV with {len(seeds)} seeds and {N_FOLDS} folds...")
    
    for s_idx, seed in enumerate(seeds):
        print(f"  🌱 Seed {s_idx+1}/{len(seeds)} (Seed: {seed})")
        kf = KFold(n_splits=N_FOLDS, shuffle=True, random_state=seed)
        
        for fold, (ti, vi) in enumerate(kf.split(X, y)):
            X_tr, y_tr = X.iloc[ti].copy(), y.iloc[ti].copy()
            X_vl, y_vl = X.iloc[vi].copy(), y.iloc[vi].copy()
            X_te = X_test.copy()
            
            # K-Fold safe Target Encoding
            for col in cat_cols:
                m_map = y_tr.groupby(X_tr[col]).mean()
                global_mean = y_tr.mean()
                X_tr[f'te_{col}'] = X_tr[col].map(m_map).fillna(global_mean)
                X_vl[f'te_{col}'] = X_vl[col].map(m_map).fillna(global_mean)
                X_te[f'te_{col}'] = X_te[col].map(m_map).fillna(global_mean)
            
            # 1. XGB
            m_xgb = xgb.XGBRegressor(n_estimators=1000, learning_rate=0.03, max_depth=6, random_state=seed, n_jobs=-1, early_stopping_rounds=50)
            m_xgb.fit(X_tr, y_tr, eval_set=[(X_vl, y_vl)], verbose=False)
            
            # 2. LGBM
            m_lgb = lgb.LGBMRegressor(n_estimators=1000, learning_rate=0.03, num_leaves=31, random_state=seed, n_jobs=-1)
            m_lgb.fit(X_tr, y_tr, eval_set=[(X_vl, y_vl)], callbacks=[lgb.early_stopping(50, verbose=False)])
            
            # 3. CatBoost (CPU version)
            m_cat = cb.CatBoostRegressor(iterations=1000, learning_rate=0.03, depth=6, random_state=seed, verbose=0, task_type='CPU')
            m_cat.fit(X_tr, y_tr, eval_set=[(X_vl, y_vl)], early_stopping_rounds=50)
            
            fold_pred = (m_xgb.predict(X_vl) + m_lgb.predict(X_vl) + m_cat.predict(X_vl)) / 3
            fold_rmse = np.sqrt(mean_squared_error(y_vl, fold_pred))
            print(f"    - Fold {fold+1} RMSE: {fold_rmse:.5f}")
            
            oof[vi] += fold_pred / len(seeds)
            test_preds += (m_xgb.predict(X_te) + m_lgb.predict(X_te) + m_cat.predict(X_te)) / (3 * N_FOLDS * len(seeds))
        
        seed_rmse = np.sqrt(mean_squared_error(y, oof * len(seeds) / (s_idx + 1)))
        print(f"  ✨ Seed {s_idx+1} OOF RMSE: {seed_rmse:.5f}")
            
    # 4. Calibration & Export
    print("[4] Calibrating and saving results...")
    iso = IsotonicRegression(out_of_bounds='clip')
    iso.fit(oof, y)
    final_test_preds = np.expm1(iso.transform(test_preds))
    
    submission = pd.DataFrame({
        'row_id': test['row_id'],
        'total_bid': final_test_preds
    })
    submission.to_csv(SUBMISSION_PATH, index=False)
    
    elapsed = time.time() - t0
    print(f"✅ V6 Elite Pipeline complete in {elapsed/60:.2f} min.")
    print(f"📁 Submission: {SUBMISSION_PATH}")

if __name__ == "__main__":
    main()
```
